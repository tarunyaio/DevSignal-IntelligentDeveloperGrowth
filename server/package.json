  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "typescript": "^5.4.5",
